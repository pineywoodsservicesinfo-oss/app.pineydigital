# Piney Digital Outreach - Environment Variables
# Copy this file to .env and fill in your values

# Google Places API (for lead scraping)
GOOGLE_API_KEY=your_google_api_key_here

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_MESSAGING_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Vapi AI Calling (get key from https://vapi.ai)
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_ID=your_vapi_phone_id_here   # Found in Vapi dashboard → Phone Numbers
VAPI_ASSISTANT_ID=your_assistant_id_here # Found in Vapi dashboard → Assistants

# AI Providers (choose one or both)
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here

# Dashboard Security (CHANGE THESE!)
DASHBOARD_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DASHBOARD_SECRET=CHANGE_ME_TO_RANDOM_STRING

# Admin email for 2FA codes
ADMIN_EMAIL=your_email@yourdomain.com

# Resend Email API (for 2FA and notifications) - recommended
RESEND_API_KEY=re_xxxxxxxxxxxx

# SMTP Email Settings (fallback for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Your Business

# Optional: Hot lead alerts and call transfers
JOEL_PHONE=+1XXXXXXXXXX